# AI Ad Pipeline — Environment Variables
# Copy this file to .env.local and fill in your keys.
# NOTE: This project uses Vite, so variables must be prefixed with VITE_ (not REACT_APP_).

# Anthropic API Key — https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Pexels API Key — https://www.pexels.com/api/
VITE_PEXELS_API_KEY=your_pexels_api_key_here

# Cloudinary Cloud Name — https://console.cloudinary.com/ (top of the dashboard)
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
